---
import Layout from "../layouts/Layout.astro";
import { Hero } from "../components/sections/Hero";
import { Experience } from "../components/sections/Experience";
import { Education } from "../components/sections/Education";
import { Work } from "../components/sections/Work";
import Separator from "../components/ui/Separator";
import { GithubCalendar } from "../components/ui/GithubGraph";
import { getEducation, getExperiences, getProfile, getProjects } from "../lib/data";

const title = "Mohamed Yessine Bouajila - Portfolio";
const description = "Full-Stack Developer & Product Manager";
const [profile, projects, experiences, education] = await Promise.all([
  getProfile(),
  getProjects(),
  getExperiences(),
  getEducation(),
]);
---

<Layout title={title} description={description} profile={profile}>
  <main class="min-h-dvh max-w-3xl mx-auto px-6">
    <Hero profile={profile} client:load />
    <Work projects={projects} client:visible />
    <Separator variant="section" client:visible />
    <Experience experiences={experiences} client:visible />
    <Separator variant="section" client:visible />
    <Education education={education} client:visible />
    <Separator variant="section" client:visible />
    <GithubCalendar client:visible />
  </main>
  
</Layout>
