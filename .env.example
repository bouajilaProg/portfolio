CMS_API_BASE_URL=http://localhost:3000/
CMS_ACCESS_TOKEN=replace-with-your-cms-access-token
CMS_CACHE_TTL_SECONDS=300
CMS_CACHE_STALE_SECONDS=1800

# Public base URL for R2 bucket (required for project images)
# This should match NEXT_PUBLIC_R2_PUBLIC_BASE_URL in the CMS
# Example: https://pub-xxxx.r2.dev or https://media.yourdomain.com
R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
